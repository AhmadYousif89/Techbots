generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  clerkUserId     String            @unique @map("clerk_user_id")
  email           String            @unique
  username        String?           @default("Anonymous")
  imageUrl        String?
  Cart            Cart?
  Order           Order[]
  CheckoutAttempt CheckoutAttempt[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("users")
}

model Cart {
  id          String     @id @default(cuid())
  clerkUserId String     @unique @map("clerk_user_id")
  user        User       @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: Cascade)
  count       Int        @default(0)
  totalValue  Decimal    @default(0.00) @map("total_value") @db.Decimal(10, 2)
  cartItems   CartItem[]
  isSynced    Boolean    @default(false) @map("is_synced")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  cartId      String   @map("cart_id")
  productAsin String   @map("product_asin")
  quantity    Int      @default(0)
  Cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product     Product  @relation(fields: [productAsin], references: [asin], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id(fields: [cartId, productAsin], name: "cartItemId", map: "id")
  @@index(fields: [cartId, productAsin])
  @@map("cart_items")
}

model Product {
  id                 String          @id @default(cuid())
  asin               String          @unique
  title              String
  brand              String
  color              String?
  price              Decimal         @default(0.00) @db.Decimal(10, 2)
  category           String
  description        String?
  rating             Float
  ratingsTotal       Int             @map("ratings_total")
  ratingBreakdown    Json            @map("rating_breakdown")
  mainImage          String          @map("main_image")
  imagesCount        Int             @default(0) @map("images_count")
  specificationsFlat String?         @map("specifications_flat")
  featureBulletsFlat String?         @map("feature_bullets_flat")
  stockQuantity      Int             @default(0) @map("stock_quantity")
  images             ProductImages[]
  topReviews         Review[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@map("products")
}

model Order {
  id                    String      @id @default(cuid())
  clerkUserId           String      @map("clerk_user_id")
  user                  User        @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: Cascade)
  stripePaymentIntentId String?     @unique @map("stripe_payment_intent_id")
  shippingInfo          Json        @map("shipping_info")
  pricePaid             Decimal     @default(0.00) @map("price_paid") @db.Decimal(10, 2)
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  orderItems            OrderItem[]

  @@index([clerkUserId])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product @relation(fields: [productAsin], references: [asin], onDelete: Restrict)
  productAsin String  @map("product_asin")
  count       Int     @default(0)

  @@index([orderId])
  @@index([productAsin])
  @@map("order_items")
}

model CheckoutAttempt {
  id                    String   @id @default(cuid())
  checkoutKey           String   @unique @map("checkout_key")
  clerkUserId           String   @map("clerk_user_id")
  user                  User     @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: Cascade)
  snapshot              Json     @map("snapshot")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  paymentIntentStatus   String?  @map("payment_intent_status")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([clerkUserId])
  @@map("checkout_attempts")
}

model PaymentEvent {
  id                    String   @id @default(cuid())
  stripeEventId         String   @unique @map("stripe_event_id")
  stripeEventType       String   @map("stripe_event_type")
  stripePaymentIntentId String   @map("stripe_payment_intent_id")
  checkoutKey           String?  @map("checkout_key")
  payload               Json     @map("payload")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([stripePaymentIntentId])
  @@index([checkoutKey])
  @@map("payment_events")
}

model ProductImages {
  id          String   @id @default(cuid())
  link        String
  variant     String
  product     Product? @relation(fields: [productAsin], references: [asin], onDelete: Restrict)
  productAsin String?  @map("product_asin")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("product_images")
}

model Review {
  id            String   @id
  title         String
  product       Product  @relation(fields: [asin], references: [asin], onDelete: Restrict)
  asin          String
  body          String
  bodyHtml      String   @map("body_html")
  link          String
  rating        Float
  date          Json
  profile       Json?
  reviewCountry String   @map("review_country")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("reviews")
}
